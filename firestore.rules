rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Treatment data: only accessible via the Firebase custom token (uid: homehd-treatment).
    // All other writes to Firestore go through Cloud Run (server-side, bypasses these rules).
    match /treatment_sessions/{id} {
      allow read, write: if request.auth != null
                         && request.auth.uid == 'homehd-treatment';
    }
    match /treatment_readings/{id} {
      allow read, write: if request.auth != null
                         && request.auth.uid == 'homehd-treatment';
    }
    // All other collections are accessed server-side — deny client access.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
